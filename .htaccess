# =====================================================================
#  Vision Angles Security – Apache .htaccess
#  Purpose: Canonicalize every URL variant to:
#           https://www.visionangles.com/<page>.html
#  This eliminates the duplicate URLs that caused the Search Console
#  / Bing Webmaster sitemap "Validation Failed" status:
#     http://www.visionangles.com/         (HTTP)
#     https://visionangles.com/            (non-www)
#     https://www.visionangles.com/index.php  (legacy PHP)
# =====================================================================

# ---------- Default document ----------
# Order matters: Apache tries index.html first, then index.php, then index.htm.
# index.php MUST be listed, otherwise sub-folders like /expense/ that ship a
# PHP front-controller will return 403 Forbidden.
DirectoryIndex index.html index.php index.htm

# ---------- Enable rewrite engine ----------
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1) Force HTTPS  (http://... -> https://...)
    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP:X-Forwarded-Proto} !=https
    RewriteRule ^ https://www.visionangles.com%{REQUEST_URI} [L,R=301,NE]

    # 2) Force www  (https://visionangles.com/... -> https://www.visionangles.com/...)
    RewriteCond %{HTTP_HOST} !^www\.visionangles\.com$ [NC]
    RewriteRule ^ https://www.visionangles.com%{REQUEST_URI} [L,R=301,NE]

    # 3) Remove legacy /index.php  -> /
    RewriteCond %{THE_REQUEST} \s/+index\.php[\s?] [NC]
    RewriteRule ^index\.php$ / [L,R=301,NE]

    # 4) Remove /index.html from the home URL  -> /
    RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
    RewriteRule ^index\.html$ / [L,R=301,NE]

    # 5) Strip trailing /index.html anywhere (defensive)
    RewriteRule ^(.*)/index\.html$ /$1/ [L,R=301,NE]
</IfModule>

# ---------- Custom error pages ----------
ErrorDocument 404 /404.html

# ---------- Security & SEO headers ----------
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    # HSTS – only after you have verified HTTPS works on every subdomain
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
</IfModule>

# ---------- Compression ----------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/json application/xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ---------- Browser caching ----------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault                              "access plus 1 month"
    ExpiresByType text/html                     "access plus 0 seconds"
    ExpiresByType text/xml                      "access plus 0 seconds"
    ExpiresByType application/xml               "access plus 0 seconds"
    ExpiresByType application/json              "access plus 0 seconds"
    ExpiresByType text/css                      "access plus 1 year"
    ExpiresByType application/javascript        "access plus 1 year"
    ExpiresByType image/webp                    "access plus 1 year"
    ExpiresByType image/png                     "access plus 1 year"
    ExpiresByType image/jpeg                    "access plus 1 year"
    ExpiresByType image/svg+xml                 "access plus 1 year"
    ExpiresByType image/x-icon                  "access plus 1 year"
    ExpiresByType video/mp4                     "access plus 1 year"
    ExpiresByType font/woff2                    "access plus 1 year"
</IfModule>

# ---------- MIME types for modern assets ----------
<IfModule mod_mime.c>
    AddType image/webp .webp
    AddType font/woff2 .woff2
    AddType application/manifest+json .webmanifest
</IfModule>

# ---------- Block access to sensitive files ----------
<FilesMatch "^\.(htaccess|htpasswd|env|gitignore|gitattributes)$">
    Require all denied
</FilesMatch>
